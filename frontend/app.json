{
  "expo": {
    "name": "ChatCRM",
    "slug": "chatcrm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": { "resizeMode": "contain", "backgroundColor": "#2563EB" },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.chatcrm.app" },
    "android": { "adaptiveIcon": { "backgroundColor": "#2563EB" }, "package": "com.chatcrm.app" },
    "web": { "bundler": "metro", "output": "static", "favicon": "./assets/favicon.png" },
    "extra": { "apiUrl": "http://localhost:5000/api" }
  }
}
